{
  "name": "bgdc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/sanity-prepare.mjs && next build",
    "prod-build": "node scripts/sanity-prepare.mjs && NODE_ENV=production next build",
    "prod-start": "NODE_ENV=production next start",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "sanity:manifest": "sanity manifest extract --path public/studio/static",
    "sanity:schema-deploy": "sanity schema deploy",
    "seed": "node -r dotenv/config scripts/seed.mjs dotenv_config_path=.env.local",
    "seed:pages": "node -r dotenv/config scripts/seed-inner-pages.mjs dotenv_config_path=.env.local",
    "seed:phase3": "node -r dotenv/config scripts/seed-phase3-pages.mjs dotenv_config_path=.env.local",
    "seed:phase4": "node -r dotenv/config scripts/seed-phase4-pages.mjs dotenv_config_path=.env.local"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.6",
    "@portabletext/react": "^6.0.2",
    "@sanity/dashboard": "^5.0.1",
    "@sanity/image-url": "^2.0.3",
    "@sanity/vision": "^5.13.0",
    "@types/mapbox-gl": "^3.4.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "mapbox-gl": "^3.21.0",
    "next": "^16.2.2",
    "next-sanity": "^12.4.5",
    "react": "19.2.3",
    "react-countup": "^6.5.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.1",
    "resend": "^6.9.3",
    "sanity": "^5.13.0",
    "sanity-plugin-media": "^4.3.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.35",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
