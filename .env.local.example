# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=                              # Server-side token (Editor permissions) — used for draft mode and mutations
NEXT_PUBLIC_SANITY_BROWSER_TOKEN=              # Optional — read-only token for live draft previewing outside Presentation Tool

# Resend
RESEND_API_KEY=
CONTACT_FORM_SENDER=noreply@yourdomain.com
CONTACT_FORM_RECIPIENT=info@yourdomain.com

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
