# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-02-19
NEXT_PUBLIC_SANITY_BROWSER_TOKEN=              # Optional — read-only token for live draft previewing outside Presentation Tool
SANITY_API_TOKEN=                              # Server-side token (Editor permissions) — used for draft mode and mutations

# Resend
RESEND_API_KEY=
CONTACT_FORM_SENDER=noreply@yourdomain.com
CONTACT_FORM_RECIPIENT=info@yourdomain.com

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=                      # Public token from mapbox.com — used for the interactive location map

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
